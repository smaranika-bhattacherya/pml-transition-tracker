# Neon PostgreSQL
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# JWT session secret — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-random-secret-here

# EmailJS — OTP email delivery (https://emailjs.com)
# Without EMAILJS_SERVICE_ID, OTPs are printed to the terminal (dev mode)
EMAILJS_SERVICE_ID=service_xxxxxxx
EMAILJS_TEMPLATE_ID=template_xxxxxxx
EMAILJS_PUBLIC_KEY=your_public_key
EMAILJS_PRIVATE_KEY=your_private_key
